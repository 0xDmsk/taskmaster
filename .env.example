# Taskmaster Configuration
# Copy this file to .env and customize for your environment

# MCP Server — override if containers can't reach the default
# TASKMASTER_HOST=192.168.64.1
# TASKMASTER_PORT=5000

# Work Directory — where assessment output goes (state DB, audit logs, loot).
# Defaults to the current working directory if not set.
# TASKMASTER_WORK_DIR=/path/to/assessments

# Optional: Proxy passed to spawned agent containers
# HTTP_PROXY=http://127.0.0.1:8080

# Optional: Mount SecLists wordlists into agent containers
# SECLISTS_PATH=/path/to/seclists

# Wait-for-completion tuning (defaults are fine for most cases)
# WAIT_DEFAULT_TIMEOUT=600   # Server-side wait timeout (seconds)
# WAIT_POLL_INTERVAL=2       # How often the server polls state (seconds)
# MCP_BRIDGE_TIMEOUT=900     # HTTP bridge read timeout — must exceed WAIT_DEFAULT_TIMEOUT
