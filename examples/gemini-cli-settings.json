{
  "mcpServers": {
    "taskmaster": {
      "command": "python3",
      "args": [
        "/absolute/path/to/taskmaster/scripts/mcp-http-bridge.py"
      ],
      "env": {
        "TASKMASTER_HOST": "127.0.0.1",
        "TASKMASTER_PORT": "5000",
        "MCP_BRIDGE_TIMEOUT": "900"
      },
      "description": "Taskmaster - Agentic Security Orchestration Platform",
      "disabled": false
    }
  },

  "globalShortcuts": {
    "taskmaster_status": "query_execution_status",
    "taskmaster_request": "request_security_action",
    "taskmaster_spawn": "spawn_agent",
    "taskmaster_wait": "wait_for_completion"
  },

  "experimentalFeatures": {
    "toolAutoApprove": false,
    "contextSharing": true
  }
}
